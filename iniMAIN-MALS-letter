-- LOGIKA SERVER HOP (Pindah Server Ter-ramai & Low Ping)
local function ServerHop()
    local PlaceID = game.PlaceId
    local JobID = game.JobId
    local url = "https://games.roblox.com/v1/games/" .. PlaceID .. "/servers/Public?sortOrder=Desc&limit=100"
    
    pcall(function()
        local raw = request({Url = url})
        local body = HttpService:JSONDecode(raw.Body)
        local Servers = {}
        if body and body.data then
            for _, v in pairs(body.data) do
                if v.playing >= 15 and v.playing <= 25 and v.id ~= JobID then
                    table.insert(Servers, v)
                end
            end
            if #Servers > 0 then
                table.sort(Servers, function(a, b) return a.ping < b.ping end)
                if queue_on_teleport then
                    queue_on_teleport('loadstring(game:HttpGet("https://raw.githubusercontent.com/aspago-lua/rbx-script/refs/heads/main/MALS-letter"))()')
                end
                game:GetService("TeleportService"):TeleportToPlaceInstance(PlaceID, Servers[1].id)
                return
            end
        end
    end)
    -- Jika gagal / tidak ada server kriteria, random hop
    game:GetService("TeleportService"):Teleport(PlaceID)
end

