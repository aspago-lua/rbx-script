            if #matches > 0 then searchPrefix = requiredLetter; isBacktracked = true end
        end
    end
    
    if #matches > 0 then
        if sortMode == "Longest" then table.sort(matches, function(a, b) return #a > #b end)
        elseif sortMode == "Shortest" then table.sort(matches, function(a, b) return #a < #b end)
        elseif sortMode == "Killer" then table.sort(matches, function(a, b) local sA, sB = GetKillerScore(a), GetKillerScore(b); if sA == sB then return #a < #b end return sA > sB end) 
        elseif sortMode == "Smart" then table.sort(matches, function(a, b) return GetAdvancedScore(a) > GetAdvancedScore(b) end) 
        elseif sortMode == "One by One" then 
            local currentLen = searchPrefix and #searchPrefix or 0
            local targetParity = (currentLen % 2 == 0) and 1 or 0
            table.sort(matches, function(a, b)
                local aMatch = (#a % 2 == targetParity)
                local bMatch = (#b % 2 == targetParity)
                if aMatch and not bMatch then return true end
                if bMatch and not aMatch then return false end
                return #a < #b 
            end)
        end
    end
    
    local displayList = {}; for i = 1, math.min(40, #matches) do table.insert(displayList, matches[i]) end
    
