local fileName = "mals_dict_v3.json"

local function FetchWords()
    if isfile and isfile(fileName) then return end
    local allWordsMap = {}
    for _, url in ipairs(DICTIONARY_URLS) do
        local succ, res = pcall(function() return request({Url = url, Method = "GET"}) end)
        if succ and res and res.Body then
            if url:find("%.json") then
                local succDecode, decoded = pcall(function() return HttpService:JSONDecode(res.Body) end)
                if succDecode then
                    for word, _ in pairs(decoded) do allWordsMap[word:lower()] = true end
                end
            else
                for word in res.Body:gmatch("[^\r\n]+") do
                    local clean = word:gsub("[%s%c]+", ""):lower()
                    if #clean > 0 then allWordsMap[clean] = true end
                end
            end
        end
    end
    local finalArray = {}
    for w, _ in pairs(allWordsMap) do table.insert(finalArray, w) end
    if #finalArray > 0 and writefile then writefile(fileName, HttpService:JSONEncode(finalArray)) end
end
FetchWords()

