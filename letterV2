-- SEARCH LOGIC WITH SMART PRIORITIZATION ======================================
-- SEARCH LOGIC WITH SMART PRIORITIZATION ======================================
local function getConsonantCount(word)
    local consonants = "bcdfghjklmnpqrstvwxyz"
    local count = 0
    local found = {}
    for char in word:gmatch(".") do
        if consonants:find(char) and not found[char] then
            count = count + 1
            found[char] = true
        end
    end
    return count
end
local function updateTopWords(input)
    topWords = {}
    input = input:lower()
    
    if input == "" then
        selectionBox.Visible = false
        resultsFrame.Visible = false
        leftArrow.Visible = false
        rightArrow.Visible = false
        for _, c in ipairs(resultsFrame:GetChildren()) do
            if c:IsA("TextLabel") then c:Destroy() end
        end
        return
    end

    -- Filter kata yang cocok
    local matches = {}
    for _, w in ipairs(allWords) do
        if w:sub(1, #input) == input and w ~= input and not usedWords[w] then
            table.insert(matches, w)
        end
    end

    -- Sistem Scoring (Semakin tinggi skor, semakin prioritas)
    table.sort(matches, function(a, b)
        local scoreA = 0
        local scoreB = 0

        -- Kriteria 1: Jumlah Konsonan (Prioritas 2 konsonan)
        local consA = getConsonantCount(a)
        local consB = getConsonantCount(b)
        if consA == 2 then scoreA = scoreA + 50 end
        if consB == 2 then scoreB = scoreB + 50 end

        -- Kriteria 2: Huruf Akhir Langka (X, Q, Z)
        local lastA = a:sub(-1)
        local lastB = b:sub(-1)
        if lastA:match("[xqz]") then scoreA = scoreA + 100 end
        if lastB:match("[xqz]") then scoreB = scoreB + 100 end

        -- Kriteria 3: Panjang Kata (Ideal length)
        local distA = math.abs(#a - CONFIG.idealLength)
        local distB = math.abs(#b - CONFIG.idealLength)
        scoreA = scoreA - distA
        scoreB = scoreB - distB

        if scoreA == scoreB then
            return a < b
        end
        return scoreA > scoreB
    end)

    topWords = matches

    if #topWords > 0 then
        resultsFrame.Visible = true
        leftArrow.Visible = true
        rightArrow.Visible = true
    else
        resultsFrame.Visible = false
        leftArrow.Visible = false
        rightArrow.Visible = false
    end

    currentPage = 1
    displayPage()

    -- [LOGIKA AUTO TROLL DENGAN JEDA MANUSIA]
    if autoTrollEnabled and #topWords > 0 then
        -- Ambil salah satu dari 3 teratas agar tidak selalu kata yang sama (biar random)
        local range = math.min(3, #topWords)
        local targetWord = topWords[math.random(1, range)]
        
        if targetWord then
            usedWords[targetWord] = true
            -- Jeda reaksi manusia (1.5 - 3 detik)
            task.wait(math.random(15, 30) / 10) 
            autoTypeWord(targetWord, searchBox.Text)
            searchBox.Text = "" 
            notify("🎯 Priority: " .. targetWord:upper())
        end
    end
end
